{
  "name": "pocket-music",
  "version": "1.0.0",
  "description": "Pixel-accurate local Spotify-style desktop music player",
  "main": "dist-electron/main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satiricalguru/Pocket-Music.git"
  },
  "author": "SpotLocal",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c magenta,cyan \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build && tsc -p tsconfig.node.json",
    "build:check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder --mac --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@fontsource/inter": "^5.0.18",
    "@snazzah/davey": "^0.1.11",
    "@tanstack/react-virtual": "^3.5.0",
    "better-sqlite3": "^11.1.2",
    "discord.js": "^14.26.4",
    "immer": "^10.1.1",
    "libsodium-wrappers": "^0.8.4",
    "lucide-react": "^0.412.0",
    "opusscript": "^0.0.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "execa": "^9.3.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^7.2.0"
  }
}
